<Window x:Class="TNovTasks.TaskListNewWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovTasks"
             mc:Ignorable="d" Height="580" Width="770"
        SizeToContent="WidthAndHeight" MinWidth="770" MinHeight="550"
        
            WindowStartupLocation="CenterScreen" 
                                                AllowsTransparency="True"
Background="Transparent"
            ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
        
        
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
              ResizeBorderThickness="5"
              GlassFrameThickness="0"
              CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
Background="White"
BorderBrush="#FF008E43"
BorderThickness="1">
        <Grid>
            <!-- Верхняя панель (кастомный заголовок) -->
                        <Border Height="30" CornerRadius="12 12 0 0"
    Background="#FF008E43" 
    VerticalAlignment="Top"
    MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" 
Click="escButton_Click" Content="✕"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle2}" 
Click="HelpButton_Click" Content="?"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Задания от ИОС" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>

            </Border>

            <!-- Основное содержимое -->
            <Border Margin="0,30,0,0">
                <StackPanel VerticalAlignment="Center" Margin="5">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Выбор фильтра -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Center">
                            <TextBlock Text="Фильтрация по назначению (ADSK_Группирование):" VerticalAlignment="Center" Margin="5" />
                            <ComboBox x:Name="TypeComboBox" Width="150" SelectionChanged="TypeComboBox_SelectionChanged"/>
                        </StackPanel>

                        <!-- Текущий фильтр -->
                        <TextBlock x:Name="CurrentFilterText" Grid.Row="2" Margin="0,5,0,5" FontWeight="Bold" Visibility="Hidden"/>

                        <!-- ListView с поддержкой Drag&Drop -->
                        <ListView x:Name="ItemsListView" Grid.Row="3" Height="400" HorizontalAlignment="Center" 
                  AllowDrop="False"
                  >
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="От кого" Width="70" DisplayMemberBinding="{Binding HoleGroupNamePart1}"/>
                                    <GridViewColumn Header="Кому" Width="70" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding HoleGroupNamePart2}" 
                       TextWrapping="Wrap" 
                       VerticalAlignment="Top"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Этаж" Width="70" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding HoleGroupNamePart3}" 
TextWrapping="Wrap" 
VerticalAlignment="Top"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Версия" Width="70" DisplayMemberBinding="{Binding HoleGroupVersion}"/>
                                    <GridViewColumn Header="Выдано" Width="130" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding HoleGroupDateInitiator}" 
TextWrapping="Wrap" 
VerticalAlignment="Top"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Статус" Width="170" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding HoleGroupStatus}" 
TextWrapping="Wrap" 
VerticalAlignment="Top"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Действие" Width="150" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding ButtonText}" 
                                        Padding="5,2"
                                        Click="ItemButton_Click"
                                        Tag="{Binding}"
                                            Visibility="{Binding IsButtonVisible, Converter={StaticResource BoolToVisibility}}"
                                        ToolTip="{Binding ButtonToolTip}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <!-- Стиль для автоматического изменения высоты строк -->
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="VerticalContentAlignment" Value="Top"/>
                                    <Setter Property="Height" Value="Auto"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource CustomButtonStyle}" Content="Закрыть" x:Name="escButton" IsCancel="True" Click="escButton_Click" MinWidth="100" MinHeight="25" Margin="5" />
                    </StackPanel>


                </StackPanel>


            </Border>
        </Grid>

    </Border>

</Window>
