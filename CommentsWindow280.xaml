<Window x:Class="TNovTasks.CommentsWindow280"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" 
        Width="500" Height="450"
        WindowStartupLocation="CenterScreen" 
        AllowsTransparency="True"
        Background="Transparent" 
        ResizeMode="NoResize" 
        WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
            Background="White"
            BorderBrush="#FF008E43"
            BorderThickness="1">
        <Grid>
            <!-- Верхняя панель -->
            <Border Height="30" CornerRadius="12 12 0 0"
                    Background="#FF008E43" 
                    VerticalAlignment="Top"
                    MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle3}" 
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle3}" 
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Комментарии" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>
            </Border>

            <!-- Основное содержимое -->
            <Grid Margin="0,30,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="{Binding TitleText, FallbackValue='Укажите комментарии к новым версиям заданий'}" 
                           Margin="10,10,10,5" 
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"/>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding Items}" 
                          AutoGenerateColumns="False" 
                          Margin="10,5,10,5" 
                          CanUserAddRows="False" 
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          BorderBrush="#CCCCCC"
                          RowHeight="30">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Группа" 
                                            Binding="{Binding HoleGroupName}" 
                                            IsReadOnly="True" 
                                            Width="*"/>
                        <DataGridTextColumn Header="Комментарии" 
                                            Binding="{Binding NewComment, UpdateSourceTrigger=PropertyChanged}" 
                                            Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Margin="5,10,5,10">
                    <Button Style="{StaticResource CustomButtonStyle}" 
                            Content="Отмена" 
                            IsCancel="True" 
                            Click="CancelButton_Click" 
                            MinWidth="90" Margin="5" Height="25"/>
                    <Button Style="{StaticResource CustomButtonStyle}" 
                            Content="Отправить" 
                            IsDefault="True" 
                            Click="SubmitButton_Click" 
                            MinWidth="90" Margin="5"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>